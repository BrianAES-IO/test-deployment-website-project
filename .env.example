# Booking embed (Cal.com or Calendly link). If unset, /book falls back to a
# plain mailto + phone call-to-action instead of an embed.
NEXT_PUBLIC_BOOKING_URL=

# Contact details shown across the site. Replace with real values before launch.
NEXT_PUBLIC_CONTACT_PHONE=+1 (876) 000-0000
NEXT_PUBLIC_CONTACT_WHATSAPP=18760000000
NEXT_PUBLIC_CONTACT_EMAIL=hello@aesurus.io

# Site URL used for metadata, sitemap.xml, and JSON-LD. Set to the production
# domain when deploying.
NEXT_PUBLIC_SITE_URL=https://aesurus.io

# Privacy-respecting analytics. Leave both unset to run with no analytics.
# Plausible: set your domain (as registered with Plausible) to enable.
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=

# Vercel Analytics: set to "true" to enable (requires deploying on Vercel).
NEXT_PUBLIC_VERCEL_ANALYTICS=

# Phase B: the two free assessment tools + /admin portal. Leave every var
# below unset and the site runs exactly like Phase A: /assessment/dpa and
# /assessment/security show a "launching this month" fallback instead of a
# broken form, and /admin simply isn't reachable. Set all 7 to go live. See
# README.md's "Phase B" section for the full setup runbook.

# Client-side Firebase config (Project Settings -> General -> your web app).
# Safe to expose in the browser bundle; Firestore itself is locked down by
# firestore.rules regardless.
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Server-only Firebase Admin SDK credentials (Project Settings -> Service
# Accounts -> Generate new private key). Never expose these to the browser;
# no NEXT_PUBLIC_ prefix on purpose. Paste the private key's \n line breaks
# as literal \n if you're pasting a single-line value here.
FIREBASE_ADMIN_PROJECT_ID=
FIREBASE_ADMIN_CLIENT_EMAIL=
FIREBASE_ADMIN_PRIVATE_KEY=
