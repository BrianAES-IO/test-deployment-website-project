rules_version = '2';

// All access to this project's Firestore data goes through the Next.js app's
// server (API routes and server components) using the Admin SDK, which
// bypasses these rules entirely. No client ever reads or writes Firestore
// directly, so every collection is locked down completely.
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
